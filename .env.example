# =============================================================================
# 旅游智能体平台 —— 环境变量模板
# =============================================================================
# 使用方法: 复制此文件为 .env，填入真实值后启动应用
#   cp .env.example .env
# =============================================================================

# ---- DeepSeek API 配置（必填） ----
# 在 https://platform.deepseek.com/api_keys 创建 API Key
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ---- 模型选择（可选，以下为默认值） ----
# 主力模型: deepseek-chat (DeepSeek-V3, 旗舰)
DEEPSEEK_MODEL=deepseek-chat
# 轻量任务的模型别名（当前统一使用 deepseek-chat）
DEEPSEEK_MODEL_FAST=deepseek-chat

# ---- 调试开关（可选） ----
# 开发环境可设为 true，生产环境务必设为 false
DEBUG=false
